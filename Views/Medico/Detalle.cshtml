@model CitasApp.Models.Medico

@{
    ViewData["Title"] = "Detalle del médico";
}

<h1>@Model.Nombre @Model.Apellido</h1>

<div class="detail-box">
    <p><strong>Especialidad:</strong> @Model.Especialidad</p>
    <p><strong>Número de licencia:</strong> @Model.NumeroLicencia</p>
</div>

<br />

<a class="action-link" asp-action="Index">Volver a la lista</a>   